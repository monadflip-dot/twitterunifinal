{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/ping", "dest": "/api/index.js" },
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/auth/(.*)", "dest": "/api/index.js" },
    { "src": "/test", "dest": "/api/index.js" },
    { "src": "/env/check", "dest": "/api/index.js" },
    { "src": "/debug/twitter", "dest": "/api/index.js" },
    { "src": "/dashboard", "dest": "/frontend/dist/index.html" },
    { "src": "/(.*)", "dest": "/frontend/dist/$1" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
