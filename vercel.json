{
  "version": 2,
  "functions": {
    "backend/index.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/ping",
      "dest": "/backend/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/auth/(.*)",
      "dest": "/backend/index.js"
    },
    {
      "src": "/test",
      "dest": "/backend/index.js"
    },
    {
      "src": "/env/check",
      "dest": "/backend/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
